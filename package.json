{
  "name": "wukkiemail",
  "version": "0.0.1",
  "private": true,
  "description": "Unified inbox — Gmail + Matrix (with bridge awareness) + eu.kiefte.issues. A Google Inbox revival.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsgo --noEmit && node --experimental-strip-types scripts/theme-contrast.mjs && vite build",
    "test:theme": "node --experimental-strip-types scripts/theme-contrast.mjs",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "lint": "eslint .",
    "deploy": "wrangler pages deploy dist"
  },
  "dependencies": {
    "@material/web": "^2.4.0",
    "dompurify": "^3.1.7",
    "emojibase": "^15.3.1",
    "emojibase-data": "^15.3.2",
    "lit": "^3.2.0",
    "livekit-client": "^2.18.0",
    "matrix-js-sdk": "github:LaPingvino/matrix-js-sdk#wally-dist",
    "matrix-widget-api": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240821.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript/native-preview": "^7.0.0-dev.20260604.1",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "eslint": "^9.9.0",
    "typescript": "^5.5.3",
    "vite": "npm:rolldown-vite@^7.3.1",
    "wrangler": "^3.72.0"
  }
}
