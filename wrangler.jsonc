{
  // Unified Workers + assets model. `wrangler deploy` reads this and
  // uploads dist/ as static assets, with functions/ as the Worker
  // entrypoint via the Pages-Functions-compatible compat flag set.
  // CF's dashboard "deploy command" defaults to `npx wrangler deploy`,
  // which only works if this file is present.
  "name": "wukkiemail",
  "compatibility_date": "2026-05-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
