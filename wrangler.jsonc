{
  // Unified Workers + assets. Worker handles /api/* (OAuth token swap,
  // refresh); everything else hits the SPA via the ASSETS binding.
  "name": "wukkiemail",
  "compatibility_date": "2026-05-01",
  "main": "src/worker.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
