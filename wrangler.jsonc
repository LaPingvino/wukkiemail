{
  // Static SPA deployment — no server-side code now that the Gmail
  // OAuth Worker is gone. CF still runs `npx wrangler deploy` so we
  // keep this config minimal; if Pages dashboard offered a blank
  // deploy command this whole file could go.
  "name": "wukkiemail",
  "compatibility_date": "2026-05-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
